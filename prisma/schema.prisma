generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Bathroom {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  description       String?
  latitude          Float
  longitude         Float
  address           String
  city              String
  state             String
  zip               String
  type              String
  isPublic          Boolean  @default(true)
  doorCode          String?
  cleanlinessRating Float    @default(3.0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([city, state])
  @@index([latitude, longitude])
}
